{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["hyprland/language", "pulseaudio", "network", "bluetooth"],

    "hyprland/workspaces": {
        "format": "{name}",
        "tooltip": false
    },

    "clock": {
        "format": "{:%a %d %b  %H:%M}",
        "tooltip": false
    },

    "hyprland/language": {
        "format": "{short}",
        "tooltip": false,
        "on-click": "hyprctl switchxkblayout all next"
    },

    "pulseaudio": {
        "format": " ",
        "format-muted": " ",
        "states": {
            "low": 33,
            "medium": 99,
            "high": 100
        },
        "scroll-step": 5.0,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": false
    },

    "network": {
        "format-wifi": " ",
        "format-ethernet": " ",
        "format-disconnected": " ",
        "tooltip": false
    },

    "bluetooth": {
        "format": " ",
        "format-connected": " ",
        "tooltip": false
    }
}
